name: Alerta Semanal Santander
on:
  schedule:
    - cron: '0 21 * * 5'  # Esto es Viernes 21:00 UTC (22:00 en España)
  workflow_dispatch:      # Esto permite dar al botón "Play" manual en GitHub

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v2
      - name: Configurar Python
        uses: actions/setup-python@v2
        with:
          python-version: '3.9'
      - name: Instalar Librerias
        run: pip install yfinance pandas matplotlib requests
      - name: Ejecutar Monitor
        run: python monitor.py
